*.disasm
*.sections.txt

# Local reverse-engineering evidence and firmware-derived reconstructions
/atmega324p_*.hex
/docs/analysis/
/docs/superpowers/
/src/reconstructed/

# Keep intentional firmware/resources/libraries, source files, documentation,
# captures, and checksums elsewhere visible to Git. Avoid broad
# *.bin/*.hex/*.fmw/*.a/*.so/*.log patterns because those files may be primary
# project inputs or test fixtures.
